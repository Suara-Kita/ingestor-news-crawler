# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis

# ─────────────────────────────────────────────
# Queues
# ─────────────────────────────────────────────
QUEUE_VOTER_INPUTS=queue:voter_inputs

# ─────────────────────────────────────────────
# Crawler
# ─────────────────────────────────────────────
POLL_INTERVAL_MINUTES=30

# ─────────────────────────────────────────────
# LLM (article summarization) — optional, leave OPENROUTER_API_KEY
# blank to skip summarization and fall back to raw scraped text
# ─────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-120b

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info
